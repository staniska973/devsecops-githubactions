# Copiez ce fichier en .env et remplissez les valeurs
# Ne committez JAMAIS le fichier .env dans Git

# Secret JWT (générez avec : openssl rand -base64 32)
JWT_SECRET=generate-a-strong-random-secret-min-32-chars

# Identifiants admin (utilisés par l'application)
ADMIN_USER=admin
ADMIN_PASS=strong-password-here

# Environnement d'exécution
NODE_ENV=production

# Port d'écoute (facultatif, défaut : 3000)
PORT=3000
